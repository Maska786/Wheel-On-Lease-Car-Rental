<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<!-- Fleet Hero Section -->
<section class="fleet-hero text-center text-white">
    <div class="container">
        <h4 class="section-subtitle mb-2">Our Premium Collection</h4>
        <h1 class="section-title mb-4" style="font-size: 3.5rem;">Explore The <span style="color: var(--gold-accent);">Elite Fleet</span></h1>
        <p class="lead opacity-75 mx-auto mb-5" style="max-width: 600px;">
            Select from our curated range of luxury vehicles maintained to the highest standards of excellence.
        </p>
    </div>
</section>

<!-- Search / Filter Widget -->
<div class="container">
    <div class="search-widget mx-auto animate-float" style="max-width: 1000px;">
        <form class="row g-3 align-items-end">
            <div class="col-lg-3 col-md-6">
                <label class="text-gold small text-uppercase fw-bold mb-2 d-block">Location</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-secondary text-gold"><i class="fas fa-map-marker-alt"></i></span>
                    <select class="form-select bg-transparent text-white border-secondary">
                        <option value="dubai">Dubai, UAE</option>
                        <option value="abudhabi">Abu Dhabi, UAE</option>
                    </select>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <label class="text-gold small text-uppercase fw-bold mb-2 d-block">Pickup Date</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-secondary text-gold"><i class="fas fa-calendar-alt"></i></span>
                    <input type="date" class="form-control bg-transparent text-white border-secondary">
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <label class="text-gold small text-uppercase fw-bold mb-2 d-block">Return Date</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-secondary text-gold"><i class="fas fa-calendar-check"></i></span>
                    <input type="date" class="form-control bg-transparent text-white border-secondary">
                </div>
            </div>
            <div class="col-lg-3 col-md-12">
                <button type="button" class="btn-premium-filled w-100 py-2 btn-shine-effect">Find Your Car</button>
            </div>
        </form>
    </div>
</div>

<!-- Category Filters -->
<div class="container mt-5">
    <div class="filter-container text-center">
        <a href="#suv" class="filter-chip active">SUV</a>
        <a href="#sedan" class="filter-chip">Sedan</a>
        <a href="#luxury" class="filter-chip">Luxury</a>
        <a href="#economy" class="filter-chip">Economy</a>
        <a href="#sports" class="filter-chip">Sports</a>
    </div>
</div>

<!-- SUV Section -->
<section id="suv" class="py-5" style="background-color: var(--bg-dark);">
  <div class="container">
    <div class="row text-center mb-5">
        <div class="col-12">
            <h2 class="section-title" style="font-size: 2.2rem;">Luxury <span style="color: var(--gold-accent);">SUVs</span></h2>
            <div class="divider mx-auto" style="width: 60px; height: 3px; background: var(--gold-accent);"></div>
        </div>
    </div>
    <div class="row g-4 d-flex align-items-stretch justify-content-center">
      {{#each suvProducts}}
      <div class="col-lg-4 col-md-6 col-sm-12">
        <div class="car-card-compact d-flex flex-column h-100">
          <div class="car-image-container">
            <span class="category-badge">SUV</span>
            <img src="{{this.image}}" alt="{{this.carName}}">
          </div>
          <div class="p-4 flex-grow-1 d-flex flex-column">
            <h5 class="fw-bold mb-2" style="font-family: 'Outfit', sans-serif; font-size: 1.4rem; color: #fff;">{{this.carName}}</h5>
            <p class="text-muted small mb-4 line-clamp-2" style="font-size: 0.9rem;">{{this.carDescription}}</p>
            
            <div class="mb-4 mt-auto">
                <div class="d-flex align-items-baseline gap-2">
                    <span class="price-tag">AED {{this.priceDaily}}</span>
                    <span class="price-period">/ Daily</span>
                </div>
                <div class="d-flex justify-content-between mt-2 pt-2 border-top border-secondary opacity-50">
                    <span class="small text-white">Weekly: AED {{this.priceWeekly}}</span>
                    <span class="small text-white">Monthly: AED {{this.priceMonthly}}</span>
                </div>
            </div>

            <div class="row g-2">
                <div class="col-4">
                    <a href="https://wa.me/971507061253" target="_blank" class="btn btn-outline-success w-100 py-2" style="border-radius: 10px; border-color: #25D366; color: #25D366;">
                        <i class="fab fa-whatsapp"></i>
                    </a>
                </div>
                <div class="col-8">
                    <button type="button" 
                       class="btn-premium-filled w-100 py-2 text-center text-decoration-none btn-shine-effect rent-now-btn" 
                       data-car-id="{{this._id}}" 
                       data-car-name="{{this.carName}}"
                       style="border-radius: 10px; font-size: 0.9rem; border: none;">
                        Rent Now
                    </button>
                </div>
            </div>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
</section>

<!-- Sedan Section -->
<section id="sedan" class="py-5" style="background-color: var(--bg-dark);">
  <div class="container">
    <div class="row text-center mb-5">
        <div class="col-12">
            <h2 class="section-title" style="font-size: 2.2rem;">Elite <span style="color: var(--gold-accent);">Sedans</span></h2>
            <div class="divider mx-auto" style="width: 60px; height: 3px; background: var(--gold-accent);"></div>
        </div>
