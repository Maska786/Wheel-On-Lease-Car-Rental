    <div class="row g-4 d-flex align-items-stretch justify-content-center">
      {{#each sedanProducts}}
      <div class="col-lg-4 col-md-6 col-sm-12">
        <div class="car-card-compact d-flex flex-column h-100">
          <div class="car-image-container">
            <span class="category-badge">Sedan</span>
            <img src="{{this.image}}" alt="{{this.carName}}">
          </div>
          <div class="p-4 flex-grow-1 d-flex flex-column">
            <h5 class="fw-bold mb-2" style="font-family: 'Outfit', sans-serif; font-size: 1.4rem; color: #fff;">{{this.carName}}</h5>
            <p class="text-muted small mb-4 line-clamp-2" style="font-size: 0.9rem;">{{this.carDescription}}</p>
            
            <div class="mb-4 mt-auto">
                <div class="d-flex align-items-baseline gap-2">
                    <span class="price-tag">AED {{this.priceDaily}}</span>
                    <span class="price-period">/ Daily</span>
                </div>
                <div class="d-flex justify-content-between mt-2 pt-2 border-top border-secondary opacity-50">
                    <span class="small text-white">Weekly: AED {{this.priceWeekly}}</span>
                    <span class="small text-white">Monthly: AED {{this.priceMonthly}}</span>
                </div>
            </div>

            <div class="row g-2">
                <div class="col-4">
                    <a href="https://wa.me/971507061253" target="_blank" class="btn btn-outline-success w-100 py-2" style="border-radius: 10px; border-color: #25D366; color: #25D366;">
                        <i class="fab fa-whatsapp"></i>
                    </a>
                </div>
                <div class="col-8">
                    <button type="button" 
                       class="btn-premium-filled w-100 py-2 text-center text-decoration-none btn-shine-effect rent-now-btn" 
                       data-car-id="{{this._id}}" 
                       data-car-name="{{this.carName}}"
                       style="border-radius: 10px; font-size: 0.9rem; border: none;">
                        Rent Now
                    </button>
                </div>
            </div>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
</section>

<!-- Lead Capture Modal -->
<div class="modal fade" id="rentModal" tabindex="-1" aria-labelledby="rentModalLabel" aria-hidden="true" data-bs-focus="false" data-bs-backdrop="true">
  <div class="modal-dialog modal-dialog-centered" style="overflow: visible;">
    <div class="modal-content shadow-lg" style="border: 2px solid var(--gold-accent); border-radius: 20px; background-color: #0d0d0f !important; overflow: visible;">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title section-title text-gold w-100 text-center mt-3" id="rentModalLabel">Request Your Ride</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4 pt-2" style="overflow: visible;">
        <p class="text-center text-white-50 small mb-4">You are requesting details for: <br><strong id="modalCarName" class="text-gold"></strong></p>
        
        <form id="leadForm">
          <input type="hidden" id="modalCarId" name="carId">
          
          <div class="mb-3 text-start">
            <label for="leadName" class="form-label text-gold small text-uppercase fw-bold mb-2">Full Name</label>
            <input type="text" class="form-control premium-modal-input" id="leadName" name="fullName" required placeholder="Enter your full name">
          </div>
          
          <div class="mb-4 text-start">
            <label for="leadPhone" class="form-label text-gold small text-uppercase fw-bold d-block mb-2">Phone Number</label>
            <div class="iti-wrapper">
                <input type="tel" class="form-control premium-modal-input w-100" id="leadPhone" name="phoneNumber" required autocomplete="off">
            </div>
          </div>
          
          <button type="submit" class="btn-premium-filled w-100 py-3 btn-shine-effect fw-bold" id="leadSubmitBtn">Submit & Continue</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
    // Injected by server: true if user is logged in
    window.__isLoggedIn = {{#if user}}true{{else}}false{{/if}};
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const modalEl = document.getElementById('rentModal');
    const leadPhoneInput = document.querySelector("#leadPhone");
    const leadForm = document.getElementById('leadForm');
    const modalBody = modalEl.querySelector('.modal-body');
    let iti;

    // Direct access to initialize ITI
    function initITI() {
        if (!iti && typeof window.intlTelInput !== 'undefined') {
            iti = window.intlTelInput(leadPhoneInput, {
                utilsScript: "https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/18.2.1/js/utils.js",
                separateDialCode: true,
                initialCountry: "ae",
                preferredCountries: ["ae", "sa", "qa", "kw", "om", "bh", "gb", "us"],
                allowDropdown: true,
                dropdownContainer: modalBody // High-compatibility dropdown placement
            });
        }
    }

    // Modal triggers
    document.querySelectorAll('.rent-now-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const carId = this.getAttribute('data-car-id');
            const carName = this.getAttribute('data-car-name');

            // If user is already logged in, skip modal and go directly to booking
            if (window.__isLoggedIn) {
                window.location.href = '/booking/' + carId;
                return;
            }

            // Guest: show lead capture modal
            document.getElementById('modalCarName').textContent = carName;
            document.getElementById('modalCarId').value = carId;
            const bsModal = bootstrap.Modal.getOrCreateInstance(modalEl);
            bsModal.show();
        });
    });

    // Re-initialize ITI logic on show
    modalEl.addEventListener('shown.bs.modal', function () {
        initITI();
        if (iti) {
            iti.setCountry("ae");
            leadPhoneInput.focus();
        }
    });

    // Handle lead submission
    leadForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        if (!iti || !iti.isValidNumber()) {
            alert("Please enter a valid phone number.");
            return;
        }

        const submitBtn = document.getElementById('leadSubmitBtn');
        submitBtn.disabled = true;
        submitBtn.textContent = "Processing...";

        try {
            const formData = {
                carId: document.getElementById('modalCarId').value,
                fullName: document.getElementById('leadName').value,
                phoneNumber: iti.getNumber()
            };

            const response = await fetch('/capture-lead', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            });

            if (response.ok) {
                const result = await response.json();
                console.log("Lead captured, checking login status...");
                
                if (result.isLoggedIn) {
                    window.location.href = "/booking/" + formData.carId;
                } else {
                    // Redirect guest to login with join parameter and destination
                    window.location.href = "/login?join=true&redirect=/booking/" + formData.carId;
                }
            } else {
                const errorData = await response.json().catch(() => ({}));
                throw new Error(errorData.message || errorData.error || "Server returned status " + response.status);
            }
        } catch (error) {
            console.error("Submission error:", error);
            alert("Error: " + (error.message || "Unknown error occurred"));
            submitBtn.disabled = false;
            submitBtn.textContent = "Submit & Continue";
        }
    });

    // Cleanup on hide
    modalEl.addEventListener('hidden.bs.modal', function () {
        leadForm.reset();
    });
});
</script>

