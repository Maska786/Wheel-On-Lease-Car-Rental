<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<!-- SUV Section -->
<section id="suv" class="pt-5" style="background-color: var(--bg-dark);">
  <div class="row text-center mb-4">
      <div class="col-12">
          <h4 class="section-subtitle">Luxury & Space</h4>
          <h2 class="section-title">SUV Fleet</h2>
      </div>
  </div>
  <div class="container">
    <div class="row g-4 d-flex align-items-stretch justify-content-center">
      {{#each suvProducts}}
      <div class="col-lg-4 col-md-6 col-sm-12">
        <div class="glass-card d-flex flex-column" style="padding: 20px;">
          <img src="{{this.image}}" class="w-100 rounded-3 mb-3 object-fit-cover" alt="{{this.altText}}" style="height: 200px;">
          <h5 class="fw-bold text-center" style="font-family: 'Outfit', sans-serif; color: var(--gold-accent); font-size: 1.5rem;">{{this.carName}}</h5>
          <div class="divider"></div>
          <p class="desc text-center mb-4 flex-grow-1">{{this.carDescription}}</p>
          
          <div class="pricing-minimal text-center mb-4 px-3 py-2 rounded-3" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
            <div class="d-flex justify-content-between align-items-center mb-1">
              <span class="text-light opacity-75">Daily</span>
              <span class="fw-bold" style="color: var(--text-main);">AED {{this.priceDaily}}</span>
            </div>
            <div class="d-flex justify-content-between align-items-center mb-1">
              <span class="text-light opacity-75">Weekly</span>
              <span class="fw-bold" style="color: var(--text-main);">AED {{this.priceWeekly}}</span>
            </div>
            <div class="d-flex justify-content-between align-items-center">
              <span class="text-light opacity-75">Monthly</span>
              <span class="fw-bold" style="color: var(--text-main);">AED {{this.priceMonthly}}</span>
            </div>
          </div>

          <div class="d-flex justify-content-center gap-3 mt-auto">
            <a href="https://wa.me/971507061253" target="_blank" class="btn-whatsapp text-center text-decoration-none px-4">
              <i class="fab fa-whatsapp me-1"></i> Chat
            </a>
            <a href="/booking/{{this._id}}" class="btn-premium-filled text-center text-decoration-none" style="padding: 10px 20px; font-size: 0.9rem;">
              Rent Now
            </a>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
</section>

