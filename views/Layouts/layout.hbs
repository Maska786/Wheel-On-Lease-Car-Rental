<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{title}}</title>
    <link rel="icon" type="image/x-icon" href="/images/Wheels On Lease Logo.png">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/18.2.1/css/intlTelInput.css" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/forms.css">
</head>

<body>


    {{#if admin}}
    {{>admin-header}}
    {{else}}
    {{>user-header}}
    {{/if}}
    <main class="main-content pt-5">
        {{{body}}}
    </main>

    <footer class="footer-main">
        <div class="container">
            <div class="row g-5">
                <!-- Brand Section -->
                <div class="col-lg-4 col-md-6">
                    <img src="/images/Wheels On Lease Logo.png" alt="Wheels On Lease" class="footer-logo">
                    <p class="text-white-50 mb-4" style="line-height: 1.8; font-size: 1.05rem;">
                        Wheels On Lease is Dubai's premier car rental service, offering an elite fleet of luxury, exotic, and economy vehicles. Experience the ultimate driving pleasure with our seamless service.
                    </p>
                    <div class="d-flex">
                        <a href="https://www.facebook.com/wheelsonleaseae" target="_blank" class="social-btn">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a href="https://www.instagram.com/wheelsonleaseae" target="_blank" class="social-btn">
                            <i class="fab fa-instagram"></i>
                        </a>
                        <a href="#" target="_blank" class="social-btn">
                            <i class="fab fa-linkedin-in"></i>
                        </a>
                        <a href="https://wa.me/971507061253" target="_blank" class="social-btn">
                            <i class="fab fa-whatsapp"></i>
                        </a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="col-lg-2 col-md-6">
                    <h5 class="footer-heading">Quick Links</h5>
                    <div class="mt-4">
                        <a href="/" class="footer-link">Home</a>
                        <a href="/about" class="footer-link">About Us</a>
                        <a href="/fleet" class="footer-link">Our Fleet</a>
                        <a href="/Contact" class="footer-link">Contact Us</a>
                        <a href="/terms" class="footer-link">T&C</a>
                        <a href="/blog" class="footer-link">Latest Blog</a>
                    </div>
                </div>

                <!-- Car Categories -->
                <div class="col-lg-2 col-md-6">
                    <h5 class="footer-heading">Fleet</h5>
                    <div class="mt-4">
                        <a href="/fleet?category=luxury" class="footer-link">Luxury Cars</a>
                        <a href="/fleet?category=suv" class="footer-link">SUV Rentals</a>
                        <a href="/fleet?category=exotic" class="footer-link">Exotic Cars</a>
                        <a href="/fleet?category=economy" class="footer-link">Economy Cars</a>
                        <a href="/fleet?category=sports" class="footer-link">Sports Cars</a>
                    </div>
                </div>

                <!-- Newsletter -->
                <div class="col-lg-4 col-md-6">
                    <h5 class="footer-heading">Newsletter</h5>
                    <div class="newsletter-box mt-4">
                        <p class="text-white-50 mb-3" style="font-size: 0.95rem;">Subscribe to get the latest offers and fleet updates.</p>
                        <form action="/newsletter" method="POST">
                            <div class="input-group mb-0">
                                <input type="email" class="form-control" placeholder="Your Email" aria-label="Email" required>
                                <button class="btn btn-premium-filled py-0 px-3" type="submit" style="border-radius: 0 10px 10px 0;">
                                    <i class="fas fa-paper-plane"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                    <p class="mt-4 text-white fw-bold italic" style="font-family: 'Outfit', sans-serif;">
                        "Drive Your Dream Car Today!"
                    </p>
                </div>
            </div>

            <!-- Footer Bottom -->
            <div class="footer-bottom mt-5">
                <div class="row align-items-center">
                    <div class="col-md-6 text-center text-md-start">
                        <p class="mb-0 text-white-50 small">
                            © 2025 <span class="text-white fw-bold">Wheels On Lease</span>. All Rights Reserved.
                        </p>
                    </div>
                    <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                        <div class="d-flex justify-content-center justify-content-md-end gap-3">
                            <a href="/privacy" class="text-muted small text-decoration-none hover-gold">Privacy Policy</a>
                            <a href="/terms" class="text-muted small text-decoration-none hover-gold">Terms & Conditions</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>


    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/18.2.1/js/intlTelInput.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/18.2.1/js/utils.js"></script>

</body>

</html>