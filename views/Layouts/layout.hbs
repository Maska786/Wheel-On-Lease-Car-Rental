<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{title}}</title>
    <link rel="icon" type="image/x-icon" href="/images/Wheels On Lease Logo.png">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.19/css/intlTelInput.min.css" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/forms.css">
</head>

<body>


    {{#if admin}}
    {{>admin-header}}
    {{else}}
    {{>user-header}}
    {{/if}}
    <main class="main-content pt-5">
        {{{body}}}
    </main>

    <footer class="bg-dark text-white text-center text-decoration-none fw-bold">
        <!-- Grid container -->
        <div class="container p-4">
            <!-- Section: Social media -->
            <section class="mb-4">
                <div class="d-flex justify-content-center gap-3">
                    <a href="https://www.facebook.com/wheelsonleaseae" target="_blank"
                        class="btn btn-primary btn-lg rounded-circle" aria-label="Facebook">
                        <i class="fab fa-facebook-f"></i>
                    </a>
                    <a href="https://www.instagram.com/wheelsonleaseae?utm_source=qr&igsh=MTZ4dXNuZGNmMG84bg=="
                        target="_blank" class="btn btn-danger btn-lg rounded-circle" aria-label="Instagram">
                        <i class="fab fa-instagram"></i>
                    </a>
                    <a href="https://linkedin.com" target="_blank" class="btn btn-primary btn-lg rounded-circle"
                        aria-label="LinkedIn">
                        <i class="fab fa-linkedin-in"></i>
                    </a>
                </div>
            </section>

            <!-- Section: Form -->
            <section>
                <form action="">
                    <div class="row d-flex justify-content-center">
                        <div class="col-auto">
                            <p class="pt-2"><strong>Sign up for our newsletter</strong></p>
                        </div>
                        <div class="col-md-5 col-12">
                            <div class="form-outline mb-4">
                                <input type="email" id="newsletter"
                                    class="form-control bg-dark text-white rounded-pill py-2" />
                            </div>
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-outline-light rounded-pill px-5 py-1" type="submit">Submit</button>
                        </div>
                    </div>
                </form>
            </section>

            <!-- Section: Text -->
            <section class="mb-4 ">
                <p class="mt-5">"Drive Your Dream Car Today!"</p>
            </section>

            <!-- Section: Links -->
            <section>
                <div class="footer-links d-flex flex-wrap justify-content-center gap-3">
                    <a href="/" class="text-decoration-none text-white">Home</a>
                    <a href="/about" class="text-decoration-none text-white" target="_blank">About Us</a>
                    <a href="/fleet" class="text-decoration-none text-white" target="_blank">Our Fleet</a>
                    <a href="/Contact" class="text-decoration-none text-white" target="_blank">Contact Us</a>
                    <a href="/" class="text-decoration-none text-white" target="_blank">T&C</a>
                    <a href="/" class="text-decoration-none text-white" target="_blank">Blog</a>
                    <a href="/" class="text-decoration-none text-white" target="_blank">Privacy Policy</a>
                </div>
            </section>
        </div>

        <!-- Copyright -->
        <div class="text-center bg-secondary p-3 ">
            © 2025 Copyright: <a class="text-black fw-bold text-decoration-none text-white" href="#">Wheels On Lease
                Car Rental</a>
        </div>
    </footer>


    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.19/js/intlTelInput.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.19/js/utils.js"></script>

</body>

</html>