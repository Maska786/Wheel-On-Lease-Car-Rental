<header class="fixed-top">
    <div class="container">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <a class="navbar-brand" href="/">
                <img src="/images/Wheels On Lease Logo.png" alt="Logo">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about">About Us</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown"
                            aria-expanded="false">Our Fleet</a>
                        <ul class="dropdown-menu bg-black text-white">
                            <li><a class="dropdown-item" href="/fleet#sedan">Sedan</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/fleet#suv">SUV</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/contact">Contact Us</a>
                    </li>

                    {{#if admin}}
                        <li class="nav-item admin px-3">
                            <h6 class="m-0 text-white">Admin: {{admin.name}}</h6>
                        </li>
                        <li class="nav-item">
                            <a href="/admin/logout" class="btn btn-sm btn-danger">Logout</a>
                        </li>
                    {{else}}
                        <li class="p-2">
                            <a href="/login" class="btn btn-light">Login</a>
                        </li>
                    {{/if}}
                </ul>
            </div>
        </nav>
    </div>
</header>
