<section class="vh-100 bg-image signup-section">
    <div class="mask d-flex align-items-center h-100 gradient-custom-3">
        <div class="container h-100">
            <div class="row d-flex justify-content-center align-items-center h-100">
                <div class="col-9 col-md-9 col-lg-7 col-xl-6">
                    <div class="glass-card shadow-lg" style="border: 1px solid rgba(212, 175, 55, 0.2); padding: 3rem; border-radius: 1rem;">
                        <div class="text-white">
                            <h3 class="text-uppercase text-center mb-4 fw-bold" style="font-family: 'Outfit', sans-serif; color: var(--gold-accent);">Create an account</h3>

                            {{#if signupError}}
                            <div class="alert alert-danger" role="alert">
                                {{signupError}}
                            </div>
                            {{/if}}

                            <form action="/signup" method="post">
                                <div class="mb-4">
                                    <input type="text" id="form3Example1cg"
                                        class="form-control form-control-premium text-white"
                                        placeholder="Your Name" name="name" required />
                                </div>

                                <div class="mb-4">
                                    <input type="email" id="form3Example3cg"
                                        class="form-control form-control-premium text-white"
                                        placeholder="Your Email" name="email" required />
                                </div>

                                <div class="mb-4">
                                    <input type="password" id="form3Example4cg"
                                        class="form-control form-control-premium text-white"
                                        placeholder="Password" name="password" required />
                                </div>

                                <div class="mb-4">
                                    <input type="password" id="form3Example4cdg"
                                        class="form-control form-control-premium text-white"
                                        placeholder="Repeat your password" name="repeatPassword" required />
                                </div>

                                <div class="form-check d-flex justify-content-center mb-5">
                                    <input class="form-check-input me-2" type="checkbox" value="" id="form2Example3cg"
                                        required />
                                    <label class="form-check-label text-light opacity-75" for="form2Example3cg">
                                        I agree to all statements in <a href="/tandc" style="color: var(--gold-accent);" class="text-decoration-none fw-bold">Terms of service</a>
                                    </label>
                                </div>

                                <div class="d-flex justify-content-center">
                                    <button type="submit" class="btn-premium-filled w-100">Sign Up</button>
                                </div>

                                <p class="text-center text-light opacity-75 mt-4 mb-0">Already have an account?
                                    <a href="/login" style="color: var(--gold-accent);" class="fw-bold text-decoration-none">Login here</a>
                                </p>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<link rel="stylesheet" href="/stylesheets/signup.css">