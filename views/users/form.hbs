<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      {{#if success_msg}}
      <div id="success-msg" class="alert alert-success text-center">
        {{success_msg}}
      </div>
      {{/if}}
      {{#if error_msg}}
      <div id="error-msg" class="alert alert-danger text-center">
        {{error_msg}}
      </div>
      {{/if}}

      <div class="glass-card shadow-lg mt-3 p-5">
        <div class="card-body">
          <h3 class="section-title text-center mb-1">Get in Touch</h3>
          <p class="section-subtitle text-center mb-4">We would love to hear from you</p>

          <form id="getInTouch" action="/form" method="POST">
            <div class="row">
                <div class="col-md-6 mb-3">
                  <label for="firstName" class="form-label form-label-premium">First Name</label>
                  <input type="text" class="form-control form-control-premium" id="firstName" name="firstName" required />
                </div>

                <div class="col-md-6 mb-3">
                  <label for="lastName" class="form-label form-label-premium">Last Name</label>
                  <input type="text" class="form-control form-control-premium" id="lastName" name="lastName" required />
                </div>
            </div>

            <div class="mb-3">
              <label for="phoneNumber" class="form-label form-label-premium">Phone Number</label>
              <input type="tel" class="form-control form-control-premium" id="phoneNumber" name="phoneNumber" required style="width: 100%;" />
            </div>

            <div class="mb-3">
              <label for="email" class="form-label form-label-premium">Email</label>
              <input type="email" class="form-control form-control-premium" id="email" name="email" required />
            </div>

            <div class="mb-4">
              <label for="message" class="form-label form-label-premium">Message</label>
              <textarea class="form-control form-control-premium" id="message" name="message" rows="4"></textarea>
            </div>

            <button type="submit" class="btn-premium-filled w-100">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<link rel="stylesheet" href="/stylesheets/forms.css">
<!-- intl-tel-input styles & script -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.19/css/intlTelInput.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.19/js/intlTelInput.min.js"></script>
<script src="/js/forms.js"></script>
