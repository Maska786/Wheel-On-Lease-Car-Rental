<section class="login-section col-md-12 col-12">
    <video autoplay muted loop playsinline class="video-bg">
        <source src="/images/Wheels on lease-Login.mp4" type="video/mp4" />
        Your browser does not support the video tag.
    </video>
    <div class="video-overlay"></div>

    <div class="container-fluid h-100 position-relative" style="z-index: 2;">
        <div class="row h-100 align-items-center">
            <div class="col-12 col-md-5 ms-auto p-5">
                <div class="glass-card shadow-lg" style="border-radius: 1rem; border: 1px solid rgba(212, 175, 55, 0.2); padding: 3rem;">
                    <div class="text-center">
                        <form action="/login" method="post">
                            <h3 class="mb-3 fw-bold" style="font-family: 'Outfit', sans-serif; color: var(--gold-accent);">LOGIN</h3>
                            
                            {{#if joinMessage}}
                            <div class="p-3 mb-4 rounded-3" style="background: rgba(212, 175, 55, 0.1); border: 1px solid rgba(212, 175, 55, 0.3);">
                                <h5 class="text-gold mb-1 fw-bold"><i class="fas fa-crown me-2"></i> Join the Elite Club</h5>
                                <p class="text-white small m-0 opacity-75">Sign in or create an account to finalize your booking and unlock premium benefits.</p>
                            </div>
                            {{else}}
                            <p class="text-light opacity-75 mb-4">Please enter your login and password!</p>
                            {{/if}}

                            {{#if loginError}}
                            <div class="alert alert-danger" role="alert">
                                {{loginError}}
                            </div>
                            {{/if}}

                            <div class="form-floating-premium mb-3">
                                <input type="email" class="form-control form-control-premium text-white" placeholder=" "
                                    name="email" id="floatingEmail" required />
                                <label for="floatingEmail">Email Address</label>
                            </div>
                            
                            <div class="form-floating-premium mb-3">
                                <input type="password" class="form-control form-control-premium text-white" placeholder=" "
                                    name="password" id="floatingPassword" required />
                                <label for="floatingPassword">Password</label>
                                <i class="fas fa-eye password-toggle" id="togglePasswordBtn"></i>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4 text-light">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="remember" />
                                    <label class="form-check-label ms-2 opacity-75" for="remember" style="font-size: 0.9rem;"> Remember me </label>
                                </div>
                                <a href="#!" class="text-decoration-none fw-bold" style="color: var(--gold-accent); font-size: 0.9rem;">Forgot password?</a>
                            </div>

                            <button class="btn-premium-filled w-100 mb-3" type="submit">Login</button>
                            <p class="mb-3 text-light opacity-75">Don't have an account? <a href="/signup" style="color: var(--gold-accent);" class="fw-bold text-decoration-none">Sign Up</a></p>

                            <div class="divider my-4"></div>

                            <button class="btn btn-lg btn-block w-100 mb-3 text-white" style="background-color: #dd4b39; border-radius: 50px;" type="button">
                                <i class="fab fa-google me-2"></i> Sign in with Google
                            </button>
                            <button class="btn btn-lg btn-block w-100 text-white" style="background-color: #3b5998; border-radius: 50px;" type="button">
                                <i class="fab fa-facebook-f me-2"></i> Sign in with Facebook
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="image-section" style="position: relative;">
    <div class="video-overlay" style="background: rgba(0,0,0,0.7);"></div>
    <div class="container position-relative" style="z-index: 2; padding-top: 5rem; padding-bottom: 5rem;">
        <div class="row align-items-center py-5">
            <div class="col-12 text-center text-white mb-5">
                <h4 class="section-subtitle">The Premium Experience</h4>
                <h1 class="fw-bold section-title mb-4">Why Choose Us?</h1>
                <div class="divider"></div>
            </div>
            
            <div class="col-12">
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="glass-card text-center p-4">
                            <i class="fas fa-car-side fa-2x mb-3" style="color: var(--gold-accent);"></i>
                            <p>Wide Selection</p>
                            <p class="desc">A diverse fleet of brand new vehicles.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass-card text-center p-4">
                            <i class="fas fa-laptop fa-2x mb-3" style="color: var(--gold-accent);"></i>
                            <p>Quick Booking</p>
                            <p class="desc">Reserve your car quickly and conveniently.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass-card text-center p-4">
                            <i class="fas fa-road fa-2x mb-3" style="color: var(--gold-accent);"></i>
                            <p>Transparent Pricing</p>
                            <p class="desc">No hidden fees, only budget-friendly rates.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass-card text-center p-4">
                            <i class="fas fa-truck fa-2x mb-3" style="color: var(--gold-accent);"></i>
                            <p>Doorstep Delivery</p>
                            <p class="desc">We deliver the vehicle right to your location.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass-card text-center p-4">
                            <i class="fas fa-calendar-alt fa-2x mb-3" style="color: var(--gold-accent);"></i>
                            <p>Flexible Rentals</p>
                            <p class="desc">Rent by the day, week, or month.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass-card text-center p-4 d-flex flex-column justify-content-center">
                            <a href="/fleet" class="btn-premium w-100 mb-3 text-decoration-none">
                                Choose Your Car Now
                            </a>
                            <p class="text-light opacity-75 fst-italic m-0" style="font-size: 0.9rem;">"Drive Your Freedom, Drive Your Way"</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<link rel="stylesheet" href="/stylesheets/login.css">
<script>
    const togglePasswordBtn = document.getElementById('togglePasswordBtn');
    const passwordInput = document.getElementById('floatingPassword');

    if (togglePasswordBtn && passwordInput) {
        togglePasswordBtn.addEventListener('click', function () {
            // Toggle the type attribute
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);
            // Toggle the eye / eye slash icon
            this.classList.toggle('fa-eye-slash');
        });
    }
</script>