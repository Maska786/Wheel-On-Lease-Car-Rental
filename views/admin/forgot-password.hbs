<section class="login-section col-md-12 col-12" style="min-height: 100vh;">
    <!-- Same stunning video background -->
    <video autoplay muted loop playsinline class="video-bg">
        <source src="/images/Wheels on lease-Login.mp4" type="video/mp4" />
    </video>
    <div class="video-overlay"></div>

    <div class="container-fluid h-100 position-relative" style="z-index: 2;">
        <div class="row h-100 align-items-center justify-content-center" style="min-height: 100vh;">
            <div class="col-12 col-md-5 col-lg-4 p-4 p-md-5">
                <div class="glass-card shadow-lg" style="border-radius: 1rem; border: 1px solid rgba(212, 175, 55, 0.4); padding: 3rem; background: rgba(18, 18, 18, 0.85); backdrop-filter: blur(15px);">
                    <div class="text-center">
                        <form action="/admin/forgot-password" method="POST" id="forgotPassForm">
                            <i class="fas fa-satellite-dish fa-3x mb-3" style="color: var(--gold-accent);"></i>
                            <h3 class="mb-3 fw-bold" style="font-family: 'Outfit', sans-serif; color: var(--gold-accent);">ACCOUNT RECOVERY</h3>
                            
                            <p class="text-light opacity-75 mb-4" style="font-size: 0.9rem;">To initiate protocol override, please specify your registered administrative terminal address.</p>

                            {{#if error}}
                            <div class="alert alert-danger" role="alert" style="background: rgba(220, 53, 69, 0.1); border: 1px solid rgba(220, 53, 69, 0.5); color: #ff6b6b; font-size: 0.95rem;">
                                <i class="fas fa-exclamation-triangle me-1"></i> {{error}}
                            </div>
                            {{/if}}

                            <div class="form-floating-premium mb-4 text-start">
                                <input type="email" class="form-control form-control-premium text-white bg-transparent" placeholder=" "
                                    name="email" id="floatingEmail" required style="border: 2px solid rgba(212, 175, 55, 0.3);" />
                                <label for="floatingEmail"><i class="fas fa-envelope me-2" style="color: var(--gold-accent);"></i> Registered Identity (Email)</label>
                            </div>

                            <button class="btn btn-premium-filled w-100 mb-4 py-3 fw-bold rounded-pill" type="submit" style="letter-spacing: 1px; color: #000; background: var(--gold-accent);" onclick="this.innerHTML='<i class=\'fas fa-spinner fa-spin me-2\'></i> Disptaching OTP...';">
                                TRANSMIT SECURITY CODE
                            </button>
                            
                            <div class="mt-2 pt-3" style="border-top: 1px solid rgba(255,255,255,0.1);">
                                <a href="/admin/login" class="text-decoration-none hover-gold" style="color: rgba(255,255,255,0.6); font-size: 0.85rem; transition: color 0.3s;">
                                    <i class="fas fa-arrow-left me-1"></i> Cancel Recovery
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<link rel="stylesheet" href="/stylesheets/login.css">
<style>
    .login-section { min-height: 100vh; display: flex; align-items: center; background-color: #000; margin: 0; padding: 0; }
    body, html { height: 100%; }
    .glass-card:hover { box-shadow: 0 15px 35px rgba(212, 175, 55, 0.3) !important; }
    .form-floating-premium label { color: rgba(255, 255, 255, 0.6); background: transparent !important; }
    .form-floating-premium > .form-control:focus ~ label,
    .form-floating-premium > .form-control:not(:placeholder-shown) ~ label {
        color: var(--gold-accent) !important; transform: scale(.85) translateY(-2.2rem) translateX(0.15rem);
    }
</style>
