<section class="admin-dashboard position-relative" style="min-height: 100vh; background-color: #0d0d0d; color: #fff; padding-top: 120px;">
    <!-- Abstract background elements for premium feel -->
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; overflow: hidden; z-index: 0; pointer-events: none;">
        <div style="position: absolute; top: -10%; left: -10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(212,175,55,0.05) 0%, transparent 60%);"></div>
        <div style="position: absolute; bottom: -10%; right: -10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(212,175,55,0.05) 0%, transparent 60%);"></div>
    </div>

    <div class="container position-relative" style="z-index: 1;">
        <!-- Header Section -->
        <div class="row mb-5 text-center">
            <div class="col-12">
                <h5 class="section-subtitle mb-2" style="color: var(--gold-accent); letter-spacing: 2px;">FLEET MANAGEMENT</h5>
                <h1 class="fw-bold section-title mb-3" style="font-family: 'Outfit', sans-serif;">Add New Car</h1>
                <div class="divider mx-auto" style="width: 60px; height: 3px; background: var(--gold-accent); border-radius: 2px;"></div>
            </div>
        </div>

        <!-- Premium Admin Navbar -->
        {{#if admin}}
        <div class="glass-card mb-5 w-100" style="border-radius: 1rem; border: 1px solid rgba(212, 175, 55, 0.2); background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px);">
            <nav class="navbar navbar-expand-lg navbar-dark px-4 py-3">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar" style="border-color: rgba(212,175,55,0.5);">
                    <i class="fas fa-bars" style="color: var(--gold-accent);"></i>
                </button>
                <div class="collapse navbar-collapse justify-content-center" id="adminNavbar">
                    <ul class="navbar-nav gap-2 gap-lg-4 text-center">
                        <li class="nav-item">
                            <a class="nav-link text-white hover-gold fw-bold" href="/admin/dashboard"><i class="fas fa-chart-pie me-2"></i>Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white fw-bold active-admin-link" href="/admin/add-products" style="color: var(--gold-accent) !important; border-bottom: 2px solid var(--gold-accent);">
                                <i class="fas fa-plus-circle me-2"></i>Add Car
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white hover-gold fw-bold" href="/admin/view-products"><i class="fas fa-car-side me-2"></i>View Fleet</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white hover-gold fw-bold" href="/admin/bookings"><i class="fas fa-calendar-check me-2"></i>Bookings</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white hover-gold fw-bold" href="/admin/forms"><i class="fas fa-envelope-open-text me-2"></i>Submissions</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white hover-gold fw-bold" href="/admin/users"><i class="fas fa-users me-2"></i>Users</a>
                        </li>
                    </ul>
                </div>
            </nav>
        </div>
        {{/if}}

        <!-- Form Section -->
        <div class="row justify-content-center pb-5">
            <div class="col-md-10 col-lg-8">
                <div class="glass-card shadow-lg p-4 p-md-5" style="border-radius: 1rem; border: 1px solid rgba(212, 175, 55, 0.2); background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(10px);">
                    <form action="/admin/add-products" method="POST" enctype="multipart/form-data">
                        
                        <div class="row g-4">
                            <!-- Car Name -->
                            <div class="col-md-6">
                                <div class="form-floating-premium">
                                    <input type="text" class="form-control form-control-premium text-white" placeholder=" "
                                        name="carName" id="carName" required />
                                    <label for="carName"><i class="fas fa-car-side me-2"></i>Car Name & Model</label>
                                </div>
                            </div>

                            <!-- Category -->
                            <div class="col-md-6">
                                <div class="form-floating-premium">
                                    <select class="form-select form-control-premium text-white" id="carCategory" name="carCategory" required style="background-color: transparent;">
                                        <option value="" disabled selected class="text-dark">Select a category</option>
                                        <option value="SUV" class="text-dark">SUV</option>
                                        <option value="Sedan" class="text-dark">Sedan</option>
                                        <option value="Luxury" class="text-dark">Luxury</option>
                                        <option value="Exotic" class="text-dark">Exotic</option>
                                        <option value="Economy" class="text-dark">Economy</option>
                                    </select>
                                    <label for="carCategory"><i class="fas fa-tags me-2"></i>Category</label>
                                </div>
                            </div>

                            <!-- Car Image Upload -->
                            <div class="col-12">
                                <div class="form-floating-premium position-relative">
                                    <input class="form-control form-control-premium text-white" type="file" id="carImage" name="CarImage" accept="image/*" required style="padding-top: 2rem;">
                                    <label for="carImage" style="top: -0.5rem; font-size: 0.85rem;"><i class="fas fa-image me-2"></i>Upload Car Image</label>
                                </div>
                            </div>

                            <!-- Alt Text -->
                            <div class="col-12">
                                <div class="form-floating-premium">
                                    <input type="text" class="form-control form-control-premium text-white" placeholder=" "
                                        name="altText" id="altText" />
                                    <label for="altText"><i class="fas fa-closed-captioning me-2"></i>Image Alt Text (e.g., Kia Sonet 2024)</label>
                                </div>
                            </div>

                            <!-- Car Description -->
                            <div class="col-12">
                                <div class="form-floating-premium">
                                    <textarea class="form-control form-control-premium text-white" placeholder=" "
                                        name="carDescription" id="carDescription" style="height: 120px" required></textarea>
                                    <label for="carDescription"><i class="fas fa-align-left me-2"></i>Detailed Description</label>
                                </div>
                            </div>

                            <!-- Price Daily -->
                            <div class="col-md-4">
                                <div class="form-floating-premium">
                                    <input type="number" class="form-control form-control-premium text-white" placeholder=" "
                                        name="priceDaily" id="priceDaily" step="0.01" required />
                                    <label for="priceDaily"><i class="fas fa-tag me-2"></i>Daily Price ($)</label>
                                </div>
                            </div>

                            <!-- Price Weekly -->
                            <div class="col-md-4">
                                <div class="form-floating-premium">
                                    <input type="number" class="form-control form-control-premium text-white" placeholder=" "
                                        name="priceWeekly" id="priceWeekly" step="0.01" required />
                                    <label for="priceWeekly"><i class="fas fa-tag me-2"></i>Weekly Price ($)</label>
                                </div>
                            </div>

                            <!-- Price Monthly -->
                            <div class="col-md-4">
                                <div class="form-floating-premium">
                                    <input type="number" class="form-control form-control-premium text-white" placeholder=" "
                                        name="priceMonthly" id="priceMonthly" step="0.01" required />
                                    <label for="priceMonthly"><i class="fas fa-tag me-2"></i>Monthly Price ($)</label>
                                </div>
                            </div>

                            <!-- Submit Button -->
                            <div class="col-12 mt-4 text-center">
                                <button type="submit" class="btn-premium-filled w-100 py-3 fw-bold" style="letter-spacing: 2px;">
                                    <i class="fas fa-check-circle me-2"></i> ADD CAR TO FLEET
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<link rel="stylesheet" href="/stylesheets/login.css">
<style>
/* Dashboard specific styles */
.admin-dashboard .nav-link.hover-gold:hover {
    color: var(--gold-accent) !important;
    transform: translateY(-2px);
}
.admin-dashboard .nav-link {
    transition: all 0.3s ease;
}

.form-floating-premium label {
    color: rgba(255, 255, 255, 0.6);
    background: transparent !important;
}

.form-floating-premium > .form-control:focus ~ label,
.form-floating-premium > .form-control:not(:placeholder-shown) ~ label,
.form-floating-premium > .form-select ~ label {
    color: var(--gold-accent) !important;
    transform: scale(.85) translateY(-2rem) translateX(0.15rem);
}

.form-select.form-control-premium {
    padding-top: 1.625rem;
    padding-bottom: 0.625rem;
}
/* File input special fix */
input[type="file"].form-control-premium::file-selector-button {
    background-color: var(--gold-accent);
    color: #fff;
    border: none;
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
    margin-right: 15px;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.3s;
}
input[type="file"].form-control-premium::file-selector-button:hover {
    background-color: #ffe066;
}
</style>