{{#if admin}}
<h2 class="mb-4 text-center pt-5">Welcome To Admin Dashboard</h2>
<nav class="navbar navbar-expand-lg navbar-secondary bg-secondary border-bottom shadow-sm"
  style="margin-top: 80px; padding-top: 10px; padding-bottom: 10px;">
  <div class="container justify-content-center">
    <ul class="navbar-nav text-center gap-4">
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/dashboard">Dashboard</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/add-products">Add Car</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/view-products">View Products</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/bookings">Bookings</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/forms">User Forms</a>
      </li>

    </ul>
  </div>
</nav>
{{/if}}

<h1 class="text-center my-4">All Bookings</h1>

<div class="container">
  {{#if bookings.length}}
  <table class="table table-bordered table-striped">
    <thead class="table-dark">
      <tr>
        <th>Sl No.</th>
        <th>User</th>
        <th>Car</th>
        <th>Pickup Date</th>
        <th>Return Date</th>
        <th>Phone</th>
        <th>Driving License</th>
        <th>ID Document</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      {{#each bookings}}
      <tr>
        <td>{{addOne @index}}</td>
        <td>{{this.user.name}} ({{this.user.email}})</td>
        <td>{{this.car.carName}}</td>
        <td>{{this.pickupDate}}</td>
        <td>{{this.returnDate}}</td>
        <td>{{this.phone}}</td>
        <td><a href="{{this.drivingLicense}}" target="_blank">View</a></td>
        <td><a href="{{this.idDocument}}" target="_blank">View</a></td>
        <td>{{this.status}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <p>No bookings yet.</p>
  {{/if}}
</div>