<section class="admin-dashboard position-relative" style="min-height: 100vh; background-color: #0d0d0d !important; color: #ffffff !important; padding-top: 120px; padding-bottom: 50px;">
    <!-- Abstract background elements for premium feel -->
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; overflow: hidden; z-index: 0; pointer-events: none;">
        <div style="position: absolute; top: -10%; left: -10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(212,175,55,0.08) 0%, transparent 60%);"></div>
        <div style="position: absolute; bottom: -10%; right: -10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(212,175,55,0.08) 0%, transparent 60%);"></div>
    </div>

    <!-- Container -->
    <div class="container-fluid px-4 px-md-5 position-relative" style="z-index: 1;">
        <!-- Header Section -->
        <div class="row mb-5 text-center">
            <div class="col-12">
                <a href="/admin/dashboard" class="btn btn-outline-light rounded-pill mb-3 px-4 shadow-sm" style="font-size:0.9rem;"><i class="fas fa-arrow-left me-2"></i>Back to Dashboard</a>
                <h5 class="section-subtitle mb-2" style="color: var(--gold-accent); letter-spacing: 2px;">SECURITY PROTOCOLS</h5>
                <h1 class="fw-bold section-title mb-3 text-white" style="font-family: 'Outfit', sans-serif;">Change Credentials</h1>
                <div class="divider mx-auto" style="width: 60px; height: 3px; background: var(--gold-accent); border-radius: 2px;"></div>
            </div>
        </div>

        <div class="row justify-content-center pb-5">
            <div class="col-12 col-md-8 col-lg-6">
                <!-- Alerts via Handlebars -->
                {{#if error}}
                <div class="alert alert-danger shadow ms-auto me-auto mb-4" style="background: rgba(220, 53, 69, 0.1); border: 1px solid rgba(220, 53, 69, 0.5); color: #ff6b6b; border-radius: 10px;">
                    <i class="fas fa-exclamation-triangle me-2"></i> {{error}}
                </div>
                {{/if}}

                {{#if success}}
                <div class="alert alert-success shadow ms-auto me-auto mb-4" style="background: rgba(40, 167, 69, 0.1); border: 1px solid rgba(40, 167, 69, 0.5); color: #28a745; border-radius: 10px;">
                    <i class="fas fa-check-circle me-2"></i> {{success}}
                </div>
                {{/if}}

                <div class="glass-card shadow-lg p-5" style="border-radius: 1.5rem; border: 1px solid rgba(212, 175, 55, 0.4); background: #121212;">
                    
                    <form action="/admin/change-password" method="POST">
                        
                        <div class="mb-4">
                            <label class="form-label text-white-50"><i class="fas fa-envelope-open-text me-2" style="color: var(--gold-accent);"></i> Security Authorization</label>
                            <div class="d-flex align-items-center gap-3">
                                <button type="button" id="requestOtpBtn" onclick="requestOTP()" class="btn btn-outline-light rounded-pill px-4 py-3 fw-bold flex-shrink-0" style="border-width: 2px;">
                                    <i class="fas fa-paper-plane me-2"></i> Request OTP
                                </button>
                                <div class="form-floating-premium flex-grow-1 m-0">
                                    <input type="text" class="form-control form-control-premium text-white bg-transparent" id="otp" name="otp" required placeholder="Enter 6-digit Code" maxlength="6" style="border-radius: 0.8rem; padding: 0.8rem 1.2rem; letter-spacing: 5px; font-weight: bold; text-align: center;">
                                </div>
                            </div>
                            <small id="otpStatus" class="form-text text-white-50 mt-2 d-block">Click 'Request OTP' to receive an authorization code at your securely registered administrative email.</small>
                        </div>

                        <hr style="border-top: 1px dashed rgba(212, 175, 55, 0.4); margin: 30px 0;">

                        <div class="mb-4">
                            <label for="newPassword" class="form-label text-white-50"><i class="fas fa-lock me-2" style="color: var(--gold-accent);"></i> New Password</label>
                            <input type="password" class="form-control form-control-premium text-white bg-transparent" id="newPassword" name="newPassword" required placeholder="Generate highly secure password" style="border-radius: 0.8rem; padding: 0.8rem 1.2rem;">
                        </div>

                        <div class="mb-5">
                            <label for="confirmPassword" class="form-label text-white-50"><i class="fas fa-lock me-2" style="color: var(--gold-accent);"></i> Confirm New Password</label>
                            <input type="password" class="form-control form-control-premium text-white bg-transparent" id="confirmPassword" name="confirmPassword" required placeholder="Match exact sequence" style="border-radius: 0.8rem; padding: 0.8rem 1.2rem;">
                        </div>

                        <button type="submit" class="btn btn-premium-filled w-100 py-3 fw-bold rounded-pill" style="font-size: 1.1rem; letter-spacing: 1px; color: #000; background: var(--gold-accent);">
                            <i class="fas fa-shield-alt me-2"></i> Lock New Security Credentials
                        </button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>

<script>
async function requestOTP() {
    const btn = document.getElementById('requestOtpBtn');
    const statusText = document.getElementById('otpStatus');
    
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Transmitting...';
    
    try {
        const response = await fetch('/admin/generate-otp', { method: 'POST' });
        const data = await response.json();
        
        if(data.status === 'success') {
            statusText.innerHTML = '<span class="text-success"><i class="fas fa-check-circle me-1"></i> OTP Securely Dispatched!</span> Check your inbox.';
            let timeLeft = 60;
            const timer = setInterval(() => {
                btn.innerHTML = `<i class="fas fa-clock me-2"></i> Resend in ${timeLeft}s`;
                timeLeft--;
                if(timeLeft < 0) {
                    clearInterval(timer);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-paper-plane me-2"></i> Request OTP';
                }
            }, 1000);
        } else {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i> Retry Transmission';
            statusText.innerHTML = '<span class="text-danger">' + data.message + '</span>';
        }
    } catch(err) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-paper-plane me-2"></i> Request OTP';
    }
}
</script>

<style>
    .form-control-premium:focus {
        background-color: rgba(212, 175, 55, 0.05) !important;
        border-color: var(--gold-accent) !important;
        box-shadow: 0 0 0 0.25rem rgba(212, 175, 55, 0.25) !important;
    }
</style>
