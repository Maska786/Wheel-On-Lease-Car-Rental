<section class="login-section col-md-12 col-12" style="min-height: 100vh;">
    <!-- Abstract premium background -->
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; overflow: hidden; z-index: 0; background: #050505;">
        <div style="position: absolute; top: -10%; left: -10%; width: 70vw; height: 70vw; background: radial-gradient(circle, rgba(212,175,55,0.03) 0%, transparent 50%); pointer-events: none;"></div>
    </div>

    <div class="container-fluid h-100 position-relative" style="z-index: 2;">
        <div class="row h-100 align-items-center justify-content-center" style="min-height: 100vh;">
            <div class="col-12 col-md-5 col-lg-4 p-4 p-md-5">
                <div class="glass-card shadow-lg" style="border-radius: 1rem; border: 1px solid rgba(212, 175, 55, 0.4); padding: 3rem; background: rgba(18, 18, 18, 0.85); backdrop-filter: blur(15px);">
                    
                    <div class="text-center mb-4">
                        <i class="fas fa-key fa-3x mb-3" style="color: var(--gold-accent);"></i>
                        <h3 class="fw-bold mb-2 text-white" style="font-family: 'Outfit', sans-serif;">Restore Security</h3>
                        <p class="text-white-50" style="font-size: 0.9rem;">Identity Verified. Embed your new cryptographic key.</p>
                    </div>

                    <form action="/admin/reset-password" method="POST" id="resetPasswordForm">
                        
                        {{#if error}}
                        <div class="alert alert-danger" role="alert" style="background: rgba(220, 53, 69, 0.1); border: 1px solid rgba(220, 53, 69, 0.5); color: #ff6b6b; font-size: 0.95rem;">
                            <i class="fas fa-exclamation-triangle me-1"></i> {{error}}
                        </div>
                        {{/if}}

                        <div class="form-floating-premium mb-3 text-start">
                            <input type="password" class="form-control form-control-premium text-white bg-transparent" placeholder=" "
                                name="newPassword" id="newPassword" required style="border: 1px solid rgba(255, 255, 255, 0.2);" />
                            <label for="newPassword"><i class="fas fa-lock me-2 text-white-50"></i> New Password</label>
                        </div>
                        
                        <div class="form-floating-premium mb-4 text-start">
                            <input type="password" class="form-control form-control-premium text-white bg-transparent" placeholder=" "
                                name="confirmPassword" id="confirmPassword" required style="border: 1px solid rgba(255, 255, 255, 0.2);" />
                            <label for="confirmPassword"><i class="fas fa-lock me-2 text-white-50"></i> Confirm Sequence</label>
                            <i class="fas fa-eye password-toggle text-white-50" id="togglePasswordBtn" style="position: absolute; right: 15px; top: 18px; cursor: pointer;"></i>
                        </div>

                        <button class="btn btn-premium-filled w-100 mb-3 py-3 fw-bold rounded-pill" type="submit" style="letter-spacing: 1px; color: #000; background: var(--gold-accent);">
                            <i class="fas fa-save me-2"></i> LOCK & REBOOT
                        </button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>

<link rel="stylesheet" href="/stylesheets/login.css">
<style>
    .login-section { min-height: 100vh; display: flex; align-items: center; background-color: #000; margin: 0; padding: 0; }
    body, html { height: 100%; }
    .glass-card:hover { box-shadow: 0 15px 35px rgba(212, 175, 55, 0.3) !important; }
    .form-floating-premium label { color: rgba(255, 255, 255, 0.6); background: transparent !important; }
    .form-floating-premium > .form-control:focus ~ label,
    .form-floating-premium > .form-control:not(:placeholder-shown) ~ label {
        color: var(--gold-accent) !important; transform: scale(.85) translateY(-2.2rem) translateX(0.15rem);
    }
    .form-control-premium:focus { border-color: var(--gold-accent) !important; background: rgba(212, 175, 55, 0.05) !important; }
</style>

<script>
    const togglePasswordBtn = document.getElementById('togglePasswordBtn');
    const newPassword = document.getElementById('newPassword');
    const confirmPassword = document.getElementById('confirmPassword');

    if (togglePasswordBtn) {
        togglePasswordBtn.addEventListener('click', function () {
            const type = newPassword.getAttribute('type') === 'password' ? 'text' : 'password';
            newPassword.setAttribute('type', type);
            confirmPassword.setAttribute('type', type);
            this.classList.toggle('fa-eye-slash');
            this.style.color = type === 'text' ? 'var(--gold-accent)' : '';
        });
    }
</script>
