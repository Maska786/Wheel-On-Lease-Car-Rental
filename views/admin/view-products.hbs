{{#if admin}}
<h2 class="mb-4 text-center pt-5">Welcome To Admin Dashboard</h2>
<nav class="navbar navbar-expand-lg navbar-secondary bg-secondary border-bottom shadow-sm"
  style="margin-top: 80px; padding-top: 10px; padding-bottom: 10px;">
  <div class="container justify-content-center">
    <ul class="navbar-nav text-center gap-4">
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/dashboard">Dashboard</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/add-products">Add Car</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/view-products">View Products</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/bookings">Bookings</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/forms">User Forms</a>
      </li>

    </ul>
  </div>
</nav>
{{/if}}
<section>
  <div class="container-fluid">
    <div class="bg-black text-white p-0">
      <!-- Cars Table -->
      <div class="table-responsive">
        <table class="table table-bordered text-white bg-dark align-middle">
          <thead class="table-light text-dark">
            <tr>
              <th>Sl No.</th>
              <th>Car Name</th>
              <th>Image</th>
              <th>Description</th>
              <th>Daily</th>
              <th>Weekly</th>
              <th>Monthly</th>
              <th>Category</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {{#each products}}
            <tr>
              <td>{{addOne @index}}</td>
              <td>{{this.carName}}</td>
              <td><img src="{{this.image}}" alt="{{this.altText}}" class="img-fluid rounded shadow-sm"
                  style="max-width: 120px;"></td>
              <td>{{this.carDescription}}</td>
              <td>${{this.priceDaily}}</td>
              <td>${{this.priceWeekly}}</td>
              <td>${{this.priceMonthly}}</td>
              <td>{{this.carCategory}}</td>
              <td class="text-nowrap">
                <a href="/admin/edit-product/{{this._id}}" class="btn btn-sm btn-info mb-1">Edit</a>
                <a href="/admin/delete-product/{{this._id}}" class="btn btn-sm btn-danger mb-1"
                  onclick="return confirm('Are you sure you want to delete {{this.carName}}?')">Delete</a>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>