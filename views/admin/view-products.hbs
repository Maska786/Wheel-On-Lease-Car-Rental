<section class="admin-dashboard position-relative" style="min-height: 100vh; background-color: #0d0d0d !important; color: #ffffff !important; padding-top: 120px; padding-bottom: 50px;">
    <!-- Abstract background elements for premium feel -->
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; overflow: hidden; z-index: 0; pointer-events: none;">
        <div style="position: absolute; top: -10%; left: -10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(212,175,55,0.08) 0%, transparent 60%);"></div>
        <div style="position: absolute; bottom: -10%; right: -10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(212,175,55,0.08) 0%, transparent 60%);"></div>
    </div>

    <div class="container-fluid px-4 px-md-5 position-relative" style="z-index: 1;">
        <!-- Header Section -->
        <div class="row mb-5 text-center">
            <div class="col-12">
                <h5 class="section-subtitle mb-2" style="color: var(--gold-accent); letter-spacing: 2px;">INVENTORY</h5>
                <h1 class="fw-bold section-title mb-3 text-white" style="font-family: 'Outfit', sans-serif;">Manage Fleet</h1>
                <div class="divider mx-auto" style="width: 60px; height: 3px; background: var(--gold-accent); border-radius: 2px;"></div>
            </div>
        </div>

        <!-- Premium Admin Navbar -->
        {{#if admin}}
        <div class="glass-card mb-5 mx-auto" style="max-width: 900px; border-radius: 1rem; border: 1px solid rgba(212, 175, 55, 0.4); background: #1a1a1a;">
            <nav class="navbar navbar-expand-lg navbar-dark px-4 py-3">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar" style="border-color: rgba(212,175,55,0.5);">
                    <i class="fas fa-bars" style="color: var(--gold-accent);"></i>
                </button>
                <div class="collapse navbar-collapse justify-content-center" id="adminNavbar">
                    <ul class="navbar-nav gap-2 gap-lg-4 text-center">
                        <li class="nav-item">
                            <a class="nav-link text-white hover-gold fw-bold" href="/admin/dashboard"><i class="fas fa-chart-pie me-2"></i>Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white hover-gold fw-bold" href="/admin/add-products"><i class="fas fa-plus-circle me-2"></i>Add Car</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white fw-bold active-admin-link" href="/admin/view-products" style="color: var(--gold-accent) !important; border-bottom: 2px solid var(--gold-accent);">
                                <i class="fas fa-car-side me-2"></i>View Fleet
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white hover-gold fw-bold" href="/admin/bookings"><i class="fas fa-calendar-check me-2"></i>Bookings</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white hover-gold fw-bold" href="/admin/forms"><i class="fas fa-envelope-open-text me-2"></i>Submissions</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white hover-gold fw-bold" href="/admin/users"><i class="fas fa-users me-2"></i>Users</a>
                        </li>
                    </ul>
                </div>
            </nav>
        </div>
        {{/if}}

        <!-- Table Section -->
        <div class="glass-card p-4 rounded-4 shadow-lg" style="border: 1px solid rgba(212, 175, 55, 0.4); background: #141414;">
            <div class="table-responsive">
                <table class="table table-borderless table-hover align-middle premium-table text-white mb-0">
                    <thead style="border-bottom: 2px solid var(--gold-accent);">
                        <tr>
                            <th class="py-3 px-4 text-uppercase" style="color: var(--gold-accent); font-size: 0.85rem; letter-spacing: 1px;">No.</th>
                            <th class="py-3 px-4 text-uppercase" style="color: var(--gold-accent); font-size: 0.85rem; letter-spacing: 1px;">Car Details</th>
                            <th class="py-3 px-4 text-uppercase" style="color: var(--gold-accent); font-size: 0.85rem; letter-spacing: 1px;">Image</th>
                            <th class="py-3 px-4 text-uppercase" style="color: var(--gold-accent); font-size: 0.85rem; letter-spacing: 1px;">Daily</th>
                            <th class="py-3 px-4 text-uppercase" style="color: var(--gold-accent); font-size: 0.85rem; letter-spacing: 1px;">Weekly</th>
                            <th class="py-3 px-4 text-uppercase" style="color: var(--gold-accent); font-size: 0.85rem; letter-spacing: 1px;">Monthly</th>
                            <th class="py-3 px-4 text-uppercase" style="color: var(--gold-accent); font-size: 0.85rem; letter-spacing: 1px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#if products.length}}
                            {{#each products}}
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.1); background-color: #141414; transition: background-color 0.3s; color: #ffffff;">
                                <td class="px-4 py-4"><span style="color: #bbbbbb; font-weight: 500;">#{{addOne @index}}</span></td>
                                <td class="px-4 py-4">
                                    <h6 class="fw-bold mb-2 text-white" style="font-size: 1.15rem; letter-spacing: 0.5px; opacity: 1 !important;">{{this.carName}}</h6>
                                    <span class="badge rounded-pill px-3 py-1" style="background: rgba(212, 175, 55, 0.2); color: var(--gold-accent); border: 1px solid rgba(212, 175, 55, 0.6);">{{this.carCategory}}</span>
                                    <p class="mt-3 mb-0 small text-light" style="max-width: 250px; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; opacity: 0.8;">{{this.carDescription}}</p>
                                </td>
                                <td class="px-4 py-4">
                                    <div class="img-wrapper rounded-3 shadow text-center d-flex align-items-center justify-content-center overflow-hidden" style="width: 150px; height: 100px; border: 1px solid rgba(255,255,255,0.2); background-color: #000;">
                                        <img src="{{this.image}}" alt="{{this.altText}}" class="img-fluid w-100 h-100" style="object-fit: cover;">
                                    </div>
                                </td>
                                <td class="px-4 py-4 fw-bold text-white" style="font-size: 1.05rem;">
                                    <span class="currency-logo me-1" style="display:inline-flex; align-items:center;">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--gold-accent);">
                                            <path d="M9 3v18"></path>
                                            <path d="M9 3h6c4.418 0 8 3.582 8 8 0 4.418-3.582 8-8 8H9"></path>
                                            <path d="M4 10h14"></path>
                                            <path d="M4 14h14"></path>
                                        </svg>
                                    </span>
                                    {{this.priceDaily}}
                                </td>
                                <td class="px-4 py-4 fw-bold text-white" style="font-size: 1.05rem;">
                                    <span class="currency-logo me-1" style="display:inline-flex; align-items:center;">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--gold-accent);">
                                            <path d="M9 3v18"></path>
                                            <path d="M9 3h6c4.418 0 8 3.582 8 8 0 4.418-3.582 8-8 8H9"></path>
                                            <path d="M4 10h14"></path>
                                            <path d="M4 14h14"></path>
                                        </svg>
                                    </span>
                                    {{this.priceWeekly}}
                                </td>
                                <td class="px-4 py-4 fw-bold text-white" style="font-size: 1.05rem;">
                                    <span class="currency-logo me-1" style="display:inline-flex; align-items:center;">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--gold-accent);">
                                            <path d="M9 3v18"></path>
                                            <path d="M9 3h6c4.418 0 8 3.582 8 8 0 4.418-3.582 8-8 8H9"></path>
                                            <path d="M4 10h14"></path>
                                            <path d="M4 14h14"></path>
                                        </svg>
                                    </span>
                                    {{this.priceMonthly}}
                                </td>
                                <td class="px-4 py-4 ps-3 text-nowrap align-middle">
                                    <a href="/admin/edit-product/{{this._id}}" class="btn btn-sm btn-outline-light me-2 rounded-pill px-3 py-2 hover-gold-bg action-btn">
                                        <i class="fas fa-edit me-1"></i> Edit
                                    </a>
                                    <a href="/admin/delete-product/{{this._id}}" class="btn btn-sm btn-outline-danger rounded-pill px-3 py-2 action-btn" style="border-width: 1px;" onclick="return confirm('🚨 Are you absolutely sure you want to permanently delete the {{this.carName}}?')">
                                        <i class="fas fa-trash-alt me-1"></i> Delete
                                    </a>
                                </td>
                            </tr>
                            {{/each}}
                        {{else}}
                            <tr>
                                <td colspan="7" class="text-center py-5 text-white-50" style="background-color:#141414;">
                                    <i class="fas fa-car-crash fa-3x mb-3" style="color: rgba(212, 175, 55, 0.5);"></i>
                                    <h5>No vehicles found in the fleet.</h5>
                                    <p>Go to "Add Car" to populate your inventory.</p>
                                </td>
                            </tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<style>
/* Adjust hover and selection styling */
.admin-dashboard .nav-link.hover-gold:hover {
    color: var(--gold-accent) !important;
    transform: translateY(-2px);
}
.admin-dashboard .nav-link {
    transition: all 0.3s ease;
}
.premium-table tbody tr:hover {
    background-color: rgba(212, 175, 55, 0.15) !important;
}
.action-btn {
    transition: all 0.3s ease;
}
.hover-gold-bg:hover {
    background-color: var(--gold-accent) !important;
    color: #000 !important;
    border-color: var(--gold-accent) !important;
}

/* Base resets for Bootstrap table backgrounds inside our glass component */
.premium-table {
    --bs-table-bg: transparent;
    --bs-table-color: #ffffff;
    --bs-table-hover-color: #ffffff;
    --bs-table-hover-bg: rgba(212, 175, 55, 0.1);
}
.premium-table td, .premium-table th {
    background-color: transparent !important;
}
</style>