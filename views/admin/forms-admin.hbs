{{#if admin}}
<h2 class="mb-4 text-center pt-5">Welcome To Admin Dashboard</h2>
<nav class="navbar navbar-expand-lg navbar-secondary bg-secondary border-bottom shadow-sm"
  style="margin-top: 80px; padding-top: 10px; padding-bottom: 10px;">
  <div class="container justify-content-center">
    <ul class="navbar-nav text-center gap-4">
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/dashboard">Dashboard</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/add-products">Add Car</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/view-products">View Products</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/bookings">Bookings</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white fw-bold" href="/admin/forms-admin">User Forms</a>
      </li>

    </ul>
  </div>
</nav>
{{/if}}

<section class="container mt-4">
  <h1 class="text-center mb-3">Form Submissions</h1>
  <div class="table-responsive">
    <table class="table table-bordered table-striped">
      <thead class="table-dark">
        <tr>
          <th>Sl No.</th>
          <th>First Name</th>
          <th>Last Name</th>
          <th>Country Code</th>
          <th>Phone Number</th>
          <th>Email</th>
          <th>Submitted At</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each forms}}
        <tr>
          <td>{{addOne @index}}</td>
          <td>{{this.firstName}}</td>
          <td>{{this.lastName}}</td>
          <td>{{this.countryCode}}</td>
          <td>{{this.phoneNumber}}</td>
          <td>{{this.email}}</td>
          <td>{{this.createdAtFormatted}}</td>
          <td>
            <form action="/admin/delete-form/{{this._id}}" method="POST"
              onsubmit="return confirm('Are you sure you want to delete this form?')">
              <button type="submit" class="btn btn-sm btn-danger">Delete</button>
            </form>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</section>

<script src="/js/forms.js"></script>