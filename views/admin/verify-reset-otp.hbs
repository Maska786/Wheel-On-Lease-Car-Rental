<section class="login-section col-md-12 col-12" style="min-height: 100vh;">
    <!-- Abstract premium background to match portal -->
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; overflow: hidden; z-index: 0; background: #050505;">
        <div style="position: absolute; top: 20%; left: 10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(212,175,55,0.05) 0%, transparent 50%); pointer-events: none;"></div>
        <div style="position: absolute; bottom: 10%; right: 10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(212,175,55,0.05) 0%, transparent 50%); pointer-events: none;"></div>
    </div>

    <div class="container-fluid h-100 position-relative" style="z-index: 2;">
        <div class="row h-100 align-items-center justify-content-center" style="min-height: 100vh;">
            <div class="col-12 col-md-6 col-lg-5 p-4 p-md-5">
                <div class="glass-card shadow-lg text-center" style="border-radius: 1rem; border: 1px solid rgba(212, 175, 55, 0.4); padding: 3rem; background: rgba(18, 18, 18, 0.85); backdrop-filter: blur(15px);">
                    
                    <i class="fas fa-fingerprint fa-4x mb-4" style="color: var(--gold-accent);"></i>
                    <h3 class="fw-bold mb-2 text-white" style="font-family: 'Outfit', sans-serif;">Verify Identity</h3>
                    <p class="text-white-50 mb-4 px-3" style="font-size: 0.95rem;">An encrypted 6-digit access code has been dispatched to <span class="fw-bold text-white">{{email}}</span>.</p>

                    <form action="/admin/verify-reset-otp" method="POST" id="verifyOtpForm">
                        
                        {{#if error}}
                        <div class="alert alert-danger" role="alert" style="background: rgba(220, 53, 69, 0.1); border: 1px solid rgba(220, 53, 69, 0.5); color: #ff6b6b; font-size: 0.95rem;">
                            <i class="fas fa-shield-alt me-1"></i> {{error}}
                        </div>
                        {{/if}}

                        <div class="form-floating-premium mb-4 mt-3">
                            <input type="text" class="form-control form-control-premium text-white bg-transparent text-center" placeholder=" "
                                name="otp" id="otp" required maxlength="6" style="border: 2px dashed rgba(212, 175, 55, 0.4); font-size: 1.5rem; letter-spacing: 12px; font-weight: bold; border-radius: 12px; padding: 1.5rem 1rem;" />
                        </div>

                        <button class="btn btn-premium-filled w-100 mb-4 py-3 fw-bold rounded-pill" type="submit" style="letter-spacing: 1px; color: #000; background: var(--gold-accent);">
                            <i class="fas fa-unlock me-2"></i> AUTHORIZE RESET
                        </button>
                        
                        <div class="mt-2 pt-3" style="border-top: 1px solid rgba(255,255,255,0.1);">
                            <a href="/admin/login" class="text-decoration-none hover-gold" style="color: rgba(255,255,255,0.6); font-size: 0.85rem; transition: color 0.3s;">
                                <i class="fas fa-times me-1"></i> Abort Protocol
                            </a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>

<link rel="stylesheet" href="/stylesheets/login.css">
<style>
    .login-section { min-height: 100vh; display: flex; align-items: center; background-color: #000; margin: 0; padding: 0; }
    body, html { height: 100%; }
    .glass-card:hover { box-shadow: 0 15px 35px rgba(212, 175, 55, 0.3) !important; }
    .form-control-premium:focus { border-color: var(--gold-accent) !important; box-shadow: 0 0 15px rgba(212, 175, 55, 0.2) !important; background: rgba(212, 175, 55, 0.05) !important; }
    input#otp::placeholder { letter-spacing: normal !important; text-align: center; }
</style>
